# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Default settings for all files
[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# C/C++ source files
[*.{cpp,h,hpp,c}]
indent_size = 4
cpp_indent_braces = false
cpp_indent_multi_line_before_angle_bracket = true

# CMake configuration files
[*.cmake]
indent_size = 2

[CMakeLists.txt]
indent_size = 2

# JavaScript and JSON (UXP Frontend)
[*.{js,json,jsx}]
indent_size = 2

# XML/HTML
[*.{xml,html,svg}]
indent_size = 2

# Windows batch scripts
[*.{bat,cmd}]
end_of_line = crlf
charset = utf-8-bom

# PowerShell scripts
[*.{ps1}]
indent_size = 4

# Inno Setup scripts
[*.iss]
indent_size = 4

# Markdown documentation
[*.md]
trim_trailing_whitespace = false
