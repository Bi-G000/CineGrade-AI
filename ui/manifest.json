{
  "id": "com.cinegrade.ai.plugin",
  "name": "CineGrade AI",
  "version": "1.0.0",
  "main": "index.html",
  "host": [
    {
      "app": "ILST",
      "minVersion": "24.0"
    }
  ],
  "manifestVersion": 4,
  "entrypoints": [
    {
      "type": "panel",
      "id": "cinegrade.panel",
      "label": {"default": "CineGrade AI"},
      "minimumSize": {"width": 300, "height": 500},
      "maximumSize": {"width": 500, "height": 2000},
      "preferredDockedSize": {"width": 320, "height": 600},
      "preferredFloatingSize": {"width": 350, "height": 700},
      "icons": []
    }
  ]
}
